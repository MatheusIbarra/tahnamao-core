{
  "name": "tahnamao-core",
  "version": "0.1.0",
  "description": "Core backend for deliveries and future rides platform.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:unit": "jest --config jest.unit.config.cjs",
    "test:integration": "jest --config jest.integration.config.cjs",
    "test:e2e": "jest --config jest.e2e.config.cjs",
    "test:contract": "jest --config jest.contract.config.cjs",
    "openapi:generate": "ts-node scripts/generate-openapi.ts",
    "openapi:validate": "ts-node scripts/validate-openapi.ts",
    "postman:sync": "ts-node scripts/sync-postman-from-openapi.ts",
    "contracts:check": "npm run openapi:validate && npm run postman:sync",
    "ci:verify": "npm run lint && npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:contract && npm run contracts:check"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "mongoose": "^8.19.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.3",
    "@nestjs/testing": "^11.1.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.2",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^10.2.3",
    "newman": "^6.2.1",
    "openapi-schema-validator": "^12.1.3",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "testcontainers": "^11.6.0",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}